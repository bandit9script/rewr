        local function getClosestEnemyInFOV(useStaticFOV)
            local closestEnemy = nil
            local closestDistance = FOV_Radius
            local enemyFolder = getEnemyFolder()

            if not enemyFolder then return nil end
            if not AimbotEnabled and not AutoAimEnabled and not MobileAimEnabled then return nil end

            local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
            local mousePos = UserInputService:GetMouseLocation()
            local fovCenter = useStaticFOV and screenCenter or mousePos

            for _, enemy in ipairs(enemyFolder:GetChildren()) do
                local hum = enemy:FindFirstChildOfClass("Humanoid")
                local head = enemy:FindFirstChild("Head")
                
                if hum and hum.Health > 0 and head then
                    local headPos, onScreen = camera:WorldToViewportPoint(head.Position)
                    
                    if onScreen then
                        local distanceToFOV = (Vector2.new(headPos.X, headPos.Y) - fovCenter).Magnitude
                        
                        if distanceToFOV <= FOV_Radius then
                            if isVisible(head) then
                                local distanceToCenter = (Vector2.new(headPos.X, headPos.Y) - screenCenter).Magnitude
                                
                                if distanceToCenter < closestDistance then
                                    closestDistance = distanceToCenter
                                    closestEnemy = head
                                end
                            end
                        end
                    end
                end
            end
            
            return closestEnemy
        end

